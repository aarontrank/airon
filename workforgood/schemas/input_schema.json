{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentInput",
  "description": "Standard input schema all agents must accept.",
  "type": "object",
  "required": ["task", "context"],
  "properties": {
    "task": {
      "type": "string",
      "description": "Plain-language description of what the agent should do.",
      "minLength": 1
    },
    "context": {
      "type": "object",
      "description": "Structured data the agent needs to complete the task.",
      "properties": {
        "project_id": { "type": "string" },
        "volunteer_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "trigger": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "source": { "type": "string" }
          }
        }
      },
      "additionalProperties": true
    },
    "constraints": {
      "type": "object",
      "description": "Optional limits or overrides for this invocation.",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
